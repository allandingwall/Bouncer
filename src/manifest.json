{
  "manifest_version": 3,
  "name": "Bouncer",
  "version": "0.1.0",
  "description": "A strict, no-bypass website blocker.",
  "author": "Allan Dingwall",
  "homepage_url": "https://github.com/allandingwall/Bouncer",
  "browser_specific_settings": {
    "gecko": {
      "id": "bouncer@dingwall.dev",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs", "declarativeNetRequest"],
  "host_permissions": ["*://*/*"],
  "background": {
    "scripts": ["background/service-worker.ts"]
  },
  "action": {
    "default_title": "Bouncer",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked/blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
