{
  "name": "bouncer",
  "version": "0.1.0",
  "description": "A strict, no-bypass website blocker for Firefox.",
  "license": "MIT",
  "author": "Allan Dingwall",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:firefox": "web-ext run --source-dir=dist",
    "package": "web-ext build --source-dir=dist --artifacts-dir=.web-ext-artifacts --overwrite-dest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.4.0",
    "vite-plugin-web-extension": "^4.4.0",
    "vitest": "^2.0.0",
    "web-ext": "^8.2.0"
  }
}
